generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Game {
  id        String   @id @default(uuid())
  title     String   @unique
  genre     String
  price     Decimal  @db.Decimal(10, 2)
  stock     Int
  createdAt DateTime @default(now())
  sales     Sale[]
}

model Sale {
  id        String   @id @default(uuid())
  gameId    String
  price     Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  game      Game     @relation(fields: [gameId], references: [id])

  @@index([gameId])
}
