{
  "info": {
    "name": "GameStore API - .NET Aspire",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "juegoId", "value": "" }
  ],
  "item": [
    {
      "name": "1. Verificar API",
      "request": { "method": "GET", "url": "{{baseUrl}}/" },
      "event": [{
        "listen": "test",
        "script": { "exec": ["pm.test('Responde 200', () => pm.response.to.have.status(200));"] }
      }]
    },
    {
      "name": "2. Registrar videojuego",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"titulo\": \"Celeste\",\n  \"genero\": \"Plataformas\",\n  \"precio\": 12.5,\n  \"stock\": 5\n}"
        },
        "url": "{{baseUrl}}/juegos"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('Responde 201', () => pm.response.to.have.status(201));",
            "pm.collectionVariables.set('juegoId', pm.response.json().id);"
          ]
        }
      }]
    },
    {
      "name": "3. Consultar catálogo",
      "request": { "method": "GET", "url": "{{baseUrl}}/juegos" },
      "event": [{
        "listen": "test",
        "script": { "exec": ["pm.test('Responde 200', () => pm.response.to.have.status(200));"] }
      }]
    },
    {
      "name": "4. Actualizar videojuego",
      "request": {
        "method": "PATCH",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"precio\": 10,\n  \"stock\": 8\n}" },
        "url": "{{baseUrl}}/juegos/{{juegoId}}"
      },
      "event": [{
        "listen": "test",
        "script": { "exec": ["pm.test('Responde 200', () => pm.response.to.have.status(200));"] }
      }]
    },
    {
      "name": "5. Comprar videojuego",
      "request": { "method": "POST", "url": "{{baseUrl}}/juegos/{{juegoId}}/compras" },
      "event": [{
        "listen": "test",
        "script": { "exec": ["pm.test('Responde 201', () => pm.response.to.have.status(201));"] }
      }]
    }
  ]
}
